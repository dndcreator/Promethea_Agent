# Sensitive config (env-only)
API__API_KEY=your_api_key_here
API__MODEL=your_primary_model
API__FAILOVER_MODELS=["your_backup_model_1","your_backup_model_2"]

# Voice runtime (compact, recommended)
# Keep empty to reuse API__API_KEY
VOICE__API_KEY=
# openai | elevenlabs
VOICE__PROVIDER=openai
# OpenAI: gpt-4o-mini-tts | ElevenLabs: eleven_turbo_v2_5
VOICE__MODEL=gpt-4o-mini-tts
# OpenAI voice name or ElevenLabs voice_id
VOICE__VOICE=alloy
VOICE__FORMAT=mp3
VOICE__SPEED=1.0

# Voice runtime (advanced, optional)
VOICE__BASE_URL=https://api.openai.com/v1
VOICE__STT_PROVIDER=openai
VOICE__STT_MODEL=gpt-4o-mini-transcribe
VOICE__OPENAI_BASE_URL=https://api.openai.com/v1
VOICE__TTS_PROVIDER=openai
VOICE__TTS_MODEL=gpt-4o-mini-tts
VOICE__TTS_VOICE=alloy
VOICE__TTS_FORMAT=mp3
VOICE__TTS_SPEED=1.0
# If using ElevenLabs and a dedicated key:
VOICE__ELEVENLABS_API_KEY=
VOICE__ELEVENLABS_BASE_URL=https://api.elevenlabs.io

# Auth / Gateway secrets
AUTH__SECRET_KEY=change_me_to_a_long_random_string
GATEWAY_AUTH_TOKEN=

# Optional memory secrets
MEMORY__NEO4J__PASSWORD=password
MEMORY__API__API_KEY=

