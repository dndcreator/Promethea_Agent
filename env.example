# =============================================================
# Promethea env template (practical)
# Copy to .env and edit in one place.
# Keep secrets here; related runtime fields are grouped nearby.
# =============================================================

# -------------------------------------------------------------
# API (main model): usually configured together
# -------------------------------------------------------------
API__API_KEY=replace_with_your_api_key
API__BASE_URL=https://openrouter.ai/api/v1
API__MODEL=openai/gpt-4.1-mini
# Optional: comma-separated backup models
# API__FAILOVER_MODELS=openai/gpt-4.1-mini,anthropic/claude-3-haiku

# -------------------------------------------------------------
# Web search provider for the official web.search tool
# -------------------------------------------------------------
# Options: auto | brave | tavily | serpapi | searxng | duckduckgo
# auto uses the first configured provider below, then falls back to DuckDuckGo.
SEARCH__PROVIDER=auto
# Optional API-backed providers
SEARCH__BRAVE_API_KEY=
SEARCH__TAVILY_API_KEY=
SEARCH__SERPAPI_API_KEY=
# Optional self-hosted/key-free provider. Example: http://127.0.0.1:8888
SEARCH__SEARXNG_URL=

# -------------------------------------------------------------
# Auth / gateway
# -------------------------------------------------------------
# Use a long random value in real deployments.
AUTH__SECRET_KEY=replace_with_a_long_random_secret
# Set true only behind HTTPS.
AUTH__COOKIE_SECURE=false
# If set, gateway clients must provide this token when connecting.
GATEWAY_AUTH_TOKEN=

# -------------------------------------------------------------
# Voice (optional): key + provider/model settings
# -------------------------------------------------------------
# openai | elevenlabs
VOICE__PROVIDER=openai
VOICE__MODEL=gpt-4o-mini-tts
VOICE__VOICE=alloy
# Keep empty to reuse API__API_KEY
VOICE__API_KEY=
# Needed only when provider=elevenlabs
VOICE__ELEVENLABS_API_KEY=

# -------------------------------------------------------------
# Memory (default backend is neo4j): endpoint settings + secret
# -------------------------------------------------------------
# Backend options:
# - neo4j: default/core graph backend; registration requires Neo4j to be reachable.
# - sqlite_graph: local graph-capable fallback.
# - flat_memory: lightweight JSONL fallback.
# After changing MEMORY__STORE_BACKEND, restart the gateway.
MEMORY__ENABLED=true
MEMORY__STORE_BACKEND=neo4j
MEMORY__NEO4J__ENABLED=true
MEMORY__NEO4J__URI=bolt://127.0.0.1:7687
MEMORY__NEO4J__USERNAME=neo4j
MEMORY__NEO4J__PASSWORD=
MEMORY__NEO4J__DATABASE=neo4j

# Optional separate model for memory extraction
MEMORY__API__USE_MAIN_API=true
MEMORY__API__API_KEY=
