# =============================================================
# Promethea example environment file
# Copy this to .env and fill in your values.
#
# Priority order (highest wins):
#   .env / environment variables > config/default.json > code defaults
#
# IMPORTANT: API__API_KEY, API__BASE_URL, and API__MODEL
# must ALL match the same provider. Changing only the key
# will NOT work.
# =============================================================


# -------------------------------------------------------------
# API — Main model (REQUIRED)
# Choose exactly ONE of the options below.
# -------------------------------------------------------------

# Option A: OpenRouter (easiest for first-time users)
# Get a key at https://openrouter.ai
API__API_KEY=sk-or-your-key-here
API__BASE_URL=https://openrouter.ai/api/v1
API__MODEL=openai/gpt-4.1-mini
# Other OpenRouter models:
#   anthropic/claude-3-sonnet
#   google/gemma-3-27b-it:free
#   meta-llama/llama-3.3-70b-instruct

# Option B: OpenAI directly
# API__API_KEY=sk-your-openai-key
# API__BASE_URL=https://api.openai.com/v1
# API__MODEL=gpt-4.1-mini

# Option C: Local model (any OpenAI-compatible server, e.g. vLLM / Ollama)
# The API key value is arbitrary for most local servers but must not be empty.
# API__API_KEY=dummy-local-key
# API__BASE_URL=http://127.0.0.1:8001/v1
# API__MODEL=your-local-model-id

# Option D: Azure OpenAI
# API__API_KEY=your-azure-key
# API__BASE_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment
# API__MODEL=gpt-4o

# Advanced API options (optional)
# API__TEMPERATURE=0.7
# API__MAX_TOKENS=2000
# API__MAX_HISTORY_ROUNDS=10
# API__TIMEOUT=60
# API__RETRY_COUNT=2
# Comma-separated fallback models tried in order if primary fails:
# API__FAILOVER_MODELS=openai/gpt-4.1-mini,anthropic/claude-3-haiku


# -------------------------------------------------------------
# Memory system
# Choose ONE backend. Recommendation for first-time users:
#   sqlite_graph  — zero external dependencies, has graph recall
#   flat_memory   — simplest possible, JSONL file
#   neo4j         — full layered memory, requires a running Neo4j
# -------------------------------------------------------------

MEMORY__ENABLED=true
MEMORY__STORE_BACKEND=sqlite_graph

# Where to store the SQLite database (used when store_backend=sqlite_graph)
# MEMORY__SQLITE_GRAPH_PATH=memory/sqlite_graph.db

# Where to store the JSONL file (used when store_backend=flat_memory)
# MEMORY__FLAT_MEMORY_PATH=memory/flat_memory.jsonl

# Neo4j connection (only needed when store_backend=neo4j)
# MEMORY__NEO4J__ENABLED=true
# MEMORY__NEO4J__URI=bolt://127.0.0.1:7687
# MEMORY__NEO4J__USERNAME=neo4j
# MEMORY__NEO4J__PASSWORD=your-neo4j-password
# MEMORY__NEO4J__DATABASE=neo4j

# Separate model for memory extraction (defaults to main API if not set)
# MEMORY__API__USE_MAIN_API=true
# MEMORY__API__API_KEY=
# MEMORY__API__BASE_URL=
# MEMORY__API__MODEL=


# -------------------------------------------------------------
# Sandbox (security policy for tool and file operations)
# Recommended: enable in any environment beyond personal dev.
# -------------------------------------------------------------

# SANDBOX__ENABLED=false
# SANDBOX__PROFILE=off        # off | dev | strict
# SANDBOX__WORKSPACE_ACCESS=rw  # rw | ro | none
# SANDBOX__COMMAND_MODE=allowlist  # allowlist | audit
# SANDBOX__NETWORK_MODE=restricted  # restricted | none


# -------------------------------------------------------------
# System
# -------------------------------------------------------------

# SYSTEM__LOG_LEVEL=INFO   # DEBUG | INFO | WARNING | ERROR
# SYSTEM__DEBUG=false
# SYSTEM__STREAM_MODE=true


# -------------------------------------------------------------
# Reasoning (disabled by default — only enable if you need
# multi-step planning and are aware of increased token usage)
# -------------------------------------------------------------

# REASONING__ENABLED=false
# REASONING__MODE=react_tot
# REASONING__MAX_DEPTH=4
# REASONING__MAX_TOOL_CALLS=4
