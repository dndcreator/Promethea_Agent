{
  "id": "web",
  "kind": "channel",
  "name": "Web Channel",
  "description": "Built-in web UI channel",
  "version": "0.1.0",
  "configSchema": {
    "type": "object",
    "properties": {
      "enabled": { "type": "boolean" },
      "channel_config": { "type": "object" }
    },
    "additionalProperties": true
  },
  "uiSchema": {
    "fields": [
      { "key": "enabled", "type": "boolean", "label": "Enable Web Channel" },
      { "key": "channel_config", "type": "json", "label": "Channel Config (JSON)" }
    ]
  },
  "capabilities": {
    "surfaces": ["web_ui"],
    "supports_hot_reload": true
  }
}
